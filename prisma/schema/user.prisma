model User {
    id           String     @id @default(cuid())
    name         String
    email        String     @unique
    password     String
    phone        String?
    address      String?
    profileImage String?
    role         Role       @default(CUSTOMER)
    status       UserStatus @default(ACTIVE)

    technicianProfile TechnicianProfile?
    bookings Bookings[]
    review Review[]

    createdAt DateTime @default(now())
    updateAt  DateTime @updatedAt

    @@map("users")
}
