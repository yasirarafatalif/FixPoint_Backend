model Services {
    id          String @id @default(uuid())
    title       String @db.VarChar(255)
    discription String

    price    Float
    duration Int

    bookings Bookings[]

    technicianId String
    technician   TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
    createdAt    DateTime          @default(now())
    updatedAt    DateTime          @updatedAt
}
